    /* ─── Session (permanente) ─── */
    function getSession() {
      try { var r = localStorage.getItem(SESSION_KEY); return r ? JSON.parse(r) : null; }
      catch(e) { return null; }
    }
    function saveSession(d) {
      localStorage.setItem(SESSION_KEY, JSON.stringify({
        prenom:  d.prenom,
        nom:     d.nom,
        table:   d.table   || null,
        boisson: d.boisson || null,
        token:   d.token
      }));
    }
    function clearSession() { localStorage.removeItem(SESSION_KEY); }

    function getDeviceToken() {
      var t = localStorage.getItem('_dtoken');
      if (!t) { t = Math.random().toString(36).slice(2) + Date.now().toString(36); localStorage.setItem('_dtoken', t); }
      return t;
    }

    /* ─── Éléments DOM ─── */
