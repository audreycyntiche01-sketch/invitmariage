    var tableNameEl = document.getElementById('table-name');

    /* ─── Première lettre majuscule, reste minuscule ─── */
    function toTitleCase(str) {
      if (!str) return str;
      return str.toLowerCase().replace(/(?:^|\s|'|-)[a-zàâäéèêëîïôùûüç]/g, function(c) {
        return c.toUpperCase();
      });
    }

    /* ─── Résoudre l'anecdote d'une table ─── */
    function getAnecdote(tableName) {
      if (!tableName) return '';
      return TABLES[tableName.toUpperCase()] || TABLES[tableName] || '';
    }

    /* ─── Afficher le programme (depuis session ou modal Ok) ─── */
    function showProgram(s) {
      gate.style.display = 'none';
      document.getElementById('table-modal').classList.add('hidden');
      view.classList.remove('hidden');
      welcomeMsg.textContent = 'Bienvenue, ' + (s.prenom || s.nom || 'cher(e) invité(e)') + ' !';

      var rawTable  = s.table || null;
      var tableName = rawTable ? toTitleCase(rawTable) : 'À définir';
      tableNameEl.textContent = tableName;

      var anecdoteEl = document.getElementById('table-anecdote');
      if (anecdoteEl) {
        var anecdote = rawTable ? getAnecdote(rawTable) : '';
        anecdoteEl.textContent = anecdote ? '✦ ' + anecdote : '';
      }

      /* Boisson */
      var boissonEl = document.getElementById('boisson-display');
      if (boissonEl && s.boisson) {
        boissonEl.textContent = '🥂 ' + s.boisson;
      }
    }

    /* ─── Afficher le modal de confirmation (premier enregistrement) ─── */
    function showModal(s) {
      var modal = document.getElementById('table-modal');
      document.getElementById('modal-welcome').textContent =
        'Bienvenue, ' + (s.prenom || 'cher(e) invité(e)') + ' !';

      var rawTable  = s.table || null;
      var tableName = rawTable ? toTitleCase(rawTable) : 'À définir';
      document.getElementById('modal-table-name').textContent = tableName;

      var anecdote = rawTable ? getAnecdote(rawTable) : '';
      document.getElementById('modal-anecdote').textContent =
        anecdote ? '✦ ' + anecdote : (!rawTable ? 'Votre table vous sera communiquée prochainement.' : '');

      modal.classList.remove('hidden');

      /* Bouton Ok → programme */
      document.getElementById('modal-ok').onclick = function () {
        showProgram(s);
      };
    }

    /* ─── Vérification au chargement ─── */
    var session = getSession();
    if (session) showProgram(session);

    /* ─── Onglets ─── */
    var tabReg    = document.getElementById('tab-register');
    var tabRecon  = document.getElementById('tab-reconnect');
    var panelReg  = document.getElementById('panel-register');
    var panelRec  = document.getElementById('panel-reconnect');

    tabReg.addEventListener('click', function () {
      tabReg.classList.add('active');   tabRecon.classList.remove('active');
      panelReg.classList.remove('hidden'); panelRec.classList.add('hidden');
    });
    tabRecon.addEventListener('click', function () {
      tabRecon.classList.add('active'); tabReg.classList.remove('active');
      panelRec.classList.remove('hidden'); panelReg.classList.add('hidden');
    });

    /* ─── Helpers ─── */
    function setBtn(btn, loading, label) {
      btn.disabled = loading;
      btn.innerHTML = loading ? '<span class="loader"></span>Vérification…' : label;
    }
    function showErr(id, msg) { document.getElementById(id).textContent = msg; }

    /* ─────────────────────────────────
       FORMULAIRE INSCRIPTION
    ───────────────────────────────── */
    document.getElementById('reg-form').addEventListener('submit', async function (e) {
      e.preventDefault();
      showErr('reg-error', '');

      var prenom   = document.getElementById('reg-prenom').value.trim();
      var nom      = document.getElementById('reg-nom').value.trim();
      var sexe     = document.getElementById('reg-sexe').value;
      var relation = document.getElementById('reg-relation').value;
      var tel      = document.getElementById('reg-tel').value.trim();
      var allergie = document.getElementById('reg-allergie').value.trim();
      var boisson  = document.getElementById('reg-boisson').value;

      if (!prenom || !nom) { showErr('reg-error', 'Veuillez renseigner votre nom et prénom.'); return; }
      if (!sexe)           { showErr('reg-error', 'Veuillez choisir une civilité.'); return; }
      if (!relation)       { showErr('reg-error', 'Veuillez indiquer votre relation avec les mariés.'); return; }
      if (!boisson)        { showErr('reg-error', 'Veuillez choisir votre boisson.'); return; }

      var btn = document.getElementById('btn-register');
      setBtn(btn, true, 'Confirmer ma présence');

      try {
        var token = getDeviceToken();

        /* ── DEV : simulation locale avec affectation de table par relation ── */
        if (IS_DEV) {
          var DEV_TABLE_MAP = {
            'ami_cyntiche':    'CORNETTE PALACE',
            'ami_audrey':      'COLLINE DE MARRAKECH',
            'famille_cyntiche': 'PARK SINDIBAD',
            'famille_audrey':  'CINÉMA MEGARAMA RABAT'
          };
          var devTable = DEV_TABLE_MAP[relation] || 'CORNETTE PALACE';
          var devSession = { prenom: prenom, nom: nom, table: devTable, boisson: boisson, token: token };
          saveSession(devSession);
          showModal(devSession);
          return;
        }

        /* ── PROD ── */
        var resp = await fetch(APPS_SCRIPT_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain' },
          body: JSON.stringify({
            action: 'registerSoiree',
            prenom, nom, sexe, relation, tel, allergie, boisson,
            deviceToken: token
          })
        });
        var res = await resp.json();

        if (res.success) {
          var s = { prenom: res.prenom || prenom, nom: nom, table: res.table, boisson: boisson, token: token };
          saveSession(s);
          showModal(s);
        } else {
          showErr('reg-error', res.message || 'Une erreur est survenue. Réessayez.');
        }

      } catch(err) {
        showErr('reg-error', 'Erreur réseau. Réessayez dans quelques instants.');
      } finally {
        setBtn(btn, false, 'Confirmer ma présence');
      }
    });

    /* ─────────────────────────────────
       FORMULAIRE RECONNEXION
    ───────────────────────────────── */
    document.getElementById('recon-form').addEventListener('submit', async function (e) {
      e.preventDefault();
      showErr('recon-error', '');

      var prenom = document.getElementById('recon-prenom').value.trim();
      var nom    = document.getElementById('recon-nom').value.trim();

      if (!prenom || !nom) { showErr('recon-error', 'Veuillez renseigner votre nom et prénom.'); return; }

      var btn = document.getElementById('btn-reconnect');
      setBtn(btn, true, 'Accéder au programme');

      try {
        var token = getDeviceToken();

        /* ── DEV ── */
        if (IS_DEV) {
          saveSession({ prenom, nom, table: 'Table Jasmin', token });
          showProgram({ prenom, nom, table: 'Table Jasmin' });
          return;
        }

        /* ── PROD ── */
        var resp = await fetch(APPS_SCRIPT_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain' },
          body: JSON.stringify({ action: 'reconnectSoiree', prenom, nom, deviceToken: token })
        });
        var res = await resp.json();

        if (res.success) {
          saveSession({ prenom: res.prenom || prenom, nom, table: res.table, token });
          showProgram({ prenom: res.prenom || prenom, nom, table: res.table });
        } else {
          showErr('recon-error', res.message || 'Aucune inscription trouvée pour ces nom et prénom.');
        }

      } catch(err) {
        showErr('recon-error', 'Erreur réseau. Réessayez dans quelques instants.');
      } finally {
        setBtn(btn, false, 'Accéder au programme');
      }
    });

    /* ─── Carousel + Lightbox ─── */
    (function () {
      var track    = document.getElementById('car-track');
      var dots     = Array.from(document.querySelectorAll('#car-dots span'));
      var imgs     = Array.from(document.querySelectorAll('#car-track img'));
      var lightbox = document.getElementById('lightbox');
      var lbImg    = document.getElementById('lb-img');
      var lbCurrent = 0;

      /* ── Dots : mise à jour selon la photo visible ── */
      function updateDots() {
        if (!track || imgs.length === 0) return;
        var imgW    = imgs[0].offsetWidth + 12; /* largeur + gap */
        var idx     = Math.round(track.scrollLeft / imgW);
        dots.forEach(function (d, i) {
          d.classList.toggle('active', i === idx);
        });
      }
      track.addEventListener('scroll', updateDots, { passive: true });
      dots.forEach(function (d, i) {
        d.addEventListener('click', function () {
          var imgW = imgs[0].offsetWidth + 12;
          track.scrollTo({ left: i * imgW, behavior: 'smooth' });
        });
      });

      /* ── Boutons prev / next ── */
      document.getElementById('car-prev').addEventListener('click', function () {
        var imgW = imgs[0].offsetWidth + 12;
        track.scrollBy({ left: -imgW, behavior: 'smooth' });
      });
      document.getElementById('car-next').addEventListener('click', function () {
        var imgW = imgs[0].offsetWidth + 12;
        track.scrollBy({ left: imgW, behavior: 'smooth' });
      });

      /* ── Drag-to-scroll (souris) ── */
      var isDown = false, startX, scrollStart;
      track.addEventListener('mousedown', function (e) {
        isDown = true; startX = e.pageX; scrollStart = track.scrollLeft;
        track.style.userSelect = 'none';
      });
      document.addEventListener('mousemove', function (e) {
        if (!isDown) return;
        track.scrollLeft = scrollStart - (e.pageX - startX);
      });
      document.addEventListener('mouseup', function () {
        isDown = false; track.style.userSelect = '';
      });

      /* ── Lightbox ── */
      function lbOpen(idx) {
        lbCurrent = idx;
        lbImg.src = imgs[idx].src;
        lbImg.alt = imgs[idx].alt;
        lightbox.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
      function lbClose() {
        lightbox.classList.add('hidden');
        document.body.style.overflow = '';
      }
      function lbPrev() { lbOpen((lbCurrent - 1 + imgs.length) % imgs.length); }
      function lbNext() { lbOpen((lbCurrent + 1) % imgs.length); }

      imgs.forEach(function (img) {
        img.addEventListener('click', function () { lbOpen(Number(img.dataset.index)); });
      });
      document.getElementById('lb-close').addEventListener('click', lbClose);
      document.getElementById('lb-prev').addEventListener('click', lbPrev);
      document.getElementById('lb-next').addEventListener('click', lbNext);
      lightbox.addEventListener('click', function (e) { if (e.target === lightbox) lbClose(); });
      document.addEventListener('keydown', function (e) {
        if (lightbox.classList.contains('hidden')) return;
        if (e.key === 'Escape')     lbClose();
        if (e.key === 'ArrowLeft')  lbPrev();
        if (e.key === 'ArrowRight') lbNext();
      });
    })();

    /* ─── Déconnexion ─── */
    document.getElementById('btn-logout').addEventListener('click', function () {
      clearSession();
      view.classList.add('hidden');
      gate.style.display = 'flex';
    });

    /* ─────────────────────────────────
       COMPTE À REBOURS — Soirée 17 juillet 2026
       (mise à jour de tous les countdowns simultanément)
    ───────────────────────────────── */
    (function () {
      var cible = new Date('2026-07-17T18:00:00').getTime();

      function pad(n) { return n < 10 ? '0' + n : String(n); }

      function setAll(cls, val) {
        document.querySelectorAll('.' + cls).forEach(function(el) {
          el.textContent = val;
        });
      }

      function tick() {
        var diff = cible - Date.now();
        if (diff <= 0) {
          setAll('cd-j', '00'); setAll('cd-h', '00');
          setAll('cd-m', '00'); setAll('cd-s', '00');
          return;
        }
        setAll('cd-j', pad(Math.floor(diff / 86400000)));
        setAll('cd-h', pad(Math.floor((diff % 86400000) / 3600000)));
        setAll('cd-m', pad(Math.floor((diff % 3600000)  / 60000)));
        setAll('cd-s', pad(Math.floor((diff % 60000)    / 1000)));
      }

      tick();
      setInterval(tick, 1000);
    })();

  })();
  </script>

</body>
</html>
