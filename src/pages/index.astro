  <div class="split">

    <!-- ── Colonne gauche : Photo PNG (fond transparent) ── -->
    <div class="col-photo">
      <img
        src="/images/photo1.png"
        alt="Audrey & Cyntiche"
        loading="eager"
        decoding="async"
      />
    </div>

    <!-- ── Colonne droite : Contenu ── -->
    <div class="col-content">

      <!-- Bienvenue -->
      <p class="bienvenue">Bienvenue</p>
      <p class="sous-titre">au mariage de</p>

      <!-- Noms : même ligne desktop / 3 lignes mobile -->
      <h1 class="names">
        <span>Audrey</span>
        <span class="amp">&amp;</span>
        <span>Cyntiche</span>
      </h1>

      <!-- Tagline -->
      <p class="tagline">Au sillage d'un amour qui renaît chaque jour,<br>
      rejoignez-nous pour célébrer ce conte de fées.</p>

      <!-- Séparateur -->
      <div class="divider" aria-hidden="true">
        <span class="dv-line"></span>
        <span class="dv-icon">✿</span>
        <span class="dv-line"></span>
      </div>

      <!-- Compte à rebours (Arial) -->
      <div class="cd-wrapper" aria-live="polite">
        <span class="cd-title">Mariage civil dans</span>
        <div class="cd-row">
          <div class="cd-unit">
            <span class="cd-num" id="cd-j">—</span>
            <span class="cd-lbl">jours</span>
          </div>
          <span class="cd-sep" aria-hidden="true">:</span>
          <div class="cd-unit">
            <span class="cd-num" id="cd-h">—</span>
            <span class="cd-lbl">heures</span>
          </div>
          <span class="cd-sep" aria-hidden="true">:</span>
          <div class="cd-unit">
            <span class="cd-num" id="cd-m">—</span>
            <span class="cd-lbl">min</span>
          </div>
          <span class="cd-sep" aria-hidden="true">:</span>
          <div class="cd-unit">
            <span class="cd-num" id="cd-s">—</span>
            <span class="cd-lbl">sec</span>
          </div>
        </div>
      </div>

      <!-- Séparateur -->
      <div class="divider" aria-hidden="true">
        <span class="dv-line"></span>
        <span class="dv-icon">✿</span>
        <span class="dv-line"></span>
      </div>

      <!-- Boutons enveloppe (centrés) -->
      <div class="invitations" aria-label="Nos événements">

        <a href="/civil" class="env-link" aria-label="Mariage Civil et Bénédiction — 10 juillet 2026">
          <div class="envelope civil">
            <div class="env-flap"></div>
            <div class="env-bottom"></div>
            <div class="env-seal">AC</div>
            <div class="env-text">
              <span class="env-event">Mariage Civil &amp; Bénédiction</span>
              <span class="env-date">10 juillet 2026</span>
            </div>
          </div>
        </a>

        <a href="/soiree" class="env-link" aria-label="Soirée — 17 juillet 2026">
          <div class="envelope soiree">
            <div class="env-flap"></div>
            <div class="env-bottom"></div>
            <div class="env-seal">AC</div>
            <div class="env-text">
              <span class="env-event">Soirée</span>
              <span class="env-date">17 juillet 2026</span>
            </div>
          </div>
        </a>

      </div>
    </div><!-- /col-content -->
  </div><!-- /split -->

  <script>
    (function () {
      var target = new Date('2026-07-10T00:00:00');
      function pad(n) { return String(n).padStart(2, '0'); }
      function tick() {
        var diff = target - new Date();
        if (diff <= 0) {
          var w = document.querySelector('.cd-wrapper');
          if (w) w.innerHTML = '<span class="cd-title" style="color:#B22222;font-size:1rem;">C\'est le grand jour !</span>';
          return;
        }
        document.getElementById('cd-j').textContent = pad(Math.floor(diff / 86400000));
        document.getElementById('cd-h').textContent = pad(Math.floor((diff % 86400000) / 3600000));
        document.getElementById('cd-m').textContent = pad(Math.floor((diff % 3600000) / 60000));
        document.getElementById('cd-s').textContent = pad(Math.floor((diff % 60000) / 1000));
      }
      tick();
      setInterval(tick, 1000);
    })();
  </script>

</body>
